{
  "name": "inspector-programming",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "check-types": "npx tsc",
    "commitlint": "commitlint --from=$(git rev-parse $(git cherry origin/main | head -n 1 | cut -c 3-)^1)",
    "db-migrate-dev": "npm run migrate-dev --workspace @pins/inspector-programming-database",
    "db-reset-dev": "npm run reset-dev --workspace @pins/inspector-programming-database",
    "db-migrate-prod": "npm run migrate-prod --workspace @pins/inspector-programming-database",
    "db-generate": "npm run generate --workspace @pins/inspector-programming-database",
    "db-seed": "npm run seed --workspace @pins/inspector-programming-database",
    "db-seed-prod": "npm run seed:prod --workspace @pins/inspector-programming-database",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "lint": "npx eslint .",
    "prepare": "node .husky/install.mjs",
    "web": "npm run dev --workspace=inspector-programming-web",
    "test": "node --test",
    "test-coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@azure/functions": "^4.12.0",
    "@azure/identity": "^4.13.1",
    "@azure/msal-node": "^5.1.2",
    "@date-fns/tz": "^1.4.1",
    "@faker-js/faker": "^10.4.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@planning-inspectorate/data-model": "^2.31.2",
    "@prisma/adapter-mssql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "accessible-autocomplete": "^3.0.1",
    "ajv": "^8.18.0",
    "body-parser": "^2.2.2",
    "connect-redis": "^9.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "globals": "^17.5.0",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "notifications-node-client": "^8.3.2",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.6.0",
    "@types/nunjucks": "^3.2.6",
    "cookie-parser": "^1.4.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.7.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{js,ts,json,md,prisma,yml,yaml,scss}": [
      "prettier --write"
    ]
  }
}
